{
  "name": "nwca-pricing-tool",
  "version": "1.0.0",
  "description": "Northwest Custom Apparel Pricing Tool",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prestart": "node scripts/build.js",
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "heroku-postbuild": "npm run build",
    "lint": "eslint shared_components/js/builders shared_components/js/quote-builder-utils.js lib scripts/build.js config/tenant.js",
    "typecheck": "tsc -p tsconfig.json",
    "test:parity": "jest tests/unit/web-quote-cart-parity.test.js tests/unit/quick-quote-parity.test.js --verbose",
    "test:guards": "jest tests/unit/no-hardcoded-hosts.test.js tests/unit/build/ --verbose",
    "validate-docs": "node scripts/validate-memory-docs.js",
    "doc-freshness": "node scripts/doc-freshness.js",
    "quarterly-cleanup": "node scripts/quarterly-cleanup.js",
    "test": "jest --verbose",
    "test:unit": "jest tests/unit/ --verbose",
    "test:dom": "jest tests/dom/",
    "test:a11y": "jest tests/a11y/",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.js",
    "test:integration": "jest tests/integration/ --verbose",
    "test:parser": "jest tests/unit/parser --verbose",
    "test:pricing": "jest tests/unit/pricing --verbose",
    "test:utils": "jest tests/unit/utils --verbose",
    "test:coverage": "jest --coverage --verbose",
    "test:emb-calibrate": "node tests/validation/validate-2025-embroidery-pricing.js --calibrate",
    "test:emb-pricing": "node tests/validation/validate-2025-embroidery-pricing.js",
    "test:emb-pricing-verbose": "node tests/validation/validate-2025-embroidery-pricing.js --verbose",
    "test:order": "node tests/run-order.js",
    "test:batch": "node tests/e2e-batch-runner.js",
    "test:emb-ltm": "node tests/validation/validate-2025-embroidery-pricing.js --ltm-analysis",
    "capture:pricing": "node scripts/capture-pricing-baselines.js",
    "capture:pricing:headed": "node scripts/capture-pricing-baselines.js --headed",
    "capture:pricing:ci": "node scripts/capture-pricing-baselines.js --start-server",
    "test:pricing-baselines": "jest tests/integration/pricing-baselines.test.js --verbose"
  },
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.1.0",
    "@sentry/node": "^8.55.2",
    "body-parser": "^1.20.2",
    "compression": "^1.8.0",
    "cookie-session": "^2.1.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "html5-qrcode": "^2.3.8",
    "marked": "^12.0.2",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.24.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "stripe": "^19.3.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "26.1.0",
    "axios": "^1.6.0",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "eslint-plugin-no-unsanitized": "4.1.5",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^22.1.0",
    "playwright": "^1.58.2",
    "prettier": "3.9.4",
    "typescript": "6.0.3"
  }
}
